---
import config from "@/config/config.json";
import { markdownify } from "@/lib/utils/textConverter";
import { getTranslations } from "@/lib/utils/languagePerser";

const locale = Astro.currentLocale;
const menu = await getTranslations(locale || "en");
const footer = menu.footer;
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-columns">
      {
        footer.community && (
          <div>
            <p class="footer-heading">{footer.community.title}</p>
            <ul class="footer-links">
              {footer.community.links.map((link: any) => (
                <li>
                  <a href={link.url}>{link.name}</a>
                </li>
              ))}
            </ul>
          </div>
        )
      }
      {
        footer.help_links && (
          <div>
            <p class="footer-heading">{footer.help_links.title}</p>
            <ul class="footer-links">
              {footer.help_links.links.map((link: any) => (
                <li>
                  <a href={link.url}>{link.name}</a>
                </li>
              ))}
            </ul>
          </div>
        )
      }
      {
        footer.resources && (
          <div>
            <p class="footer-heading">{footer.resources.title}</p>
            <ul class="footer-links">
              {footer.resources.links.map((link: any) => (
                <li>
                  <a href={link.url}>{link.name}</a>
                </li>
              ))}
            </ul>
          </div>
        )
      }
      {
        footer.terms && (
          <div>
            <p class="footer-heading">{footer.terms.title}</p>
            <ul class="footer-links">
              {footer.terms.links.map((link: any) => (
                <li>
                  <a href={link.url}>{link.name}</a>
                </li>
              ))}
            </ul>
          </div>
        )
      }
    </div>
    <div class="footer-bottom">
      <p set:html={markdownify(config?.params?.copyright)} />
    </div>
  </div>
</footer>

<style>
  @layer starlight.core {
    .site-footer {
      margin-top: auto;
      padding: 0 var(--sl-content-pad-x, 1rem);
    }

    .footer-inner {
      max-width: 72rem;
      margin: 0 auto;
    }

    .footer-columns {
      border-top: 1px solid var(--sl-color-gray-6);
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
      gap: 2rem;
      padding: 2.5rem 0 2rem;
    }

    .footer-heading {
      font-size: 1.0625rem;
      font-weight: 500;
      color: var(--sl-color-white);
      margin: 0 0 0.75rem;
    }

    .footer-links {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .footer-links a {
      color: var(--sl-color-gray-3);
      text-decoration: none;
      font-size: 0.875rem;
      transition: color 0.2s ease;
    }

    .footer-links a:hover {
      color: var(--sl-color-accent);
    }

    .footer-bottom {
      border-top: 1px solid var(--sl-color-gray-6);
      padding: 1.25rem 0;
      text-align: center;
      font-size: 0.8125rem;
      color: var(--sl-color-gray-3);
    }

    :root[data-theme="light"] .footer-columns {
      border-top-color: var(--sl-color-gray-5);
    }

    :root[data-theme="light"] .footer-bottom {
      border-top-color: var(--sl-color-gray-5);
    }

    .footer-bottom a {
      color: var(--sl-color-gray-3);
      text-decoration: none;
      transition: color 0.2s ease;
    }

    .footer-bottom a:hover {
      color: var(--sl-color-accent);
    }
  }
</style>
