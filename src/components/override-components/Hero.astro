---
import CommonsCard from "~/components/user-components/CommonsCard.astro";

const route = Astro.locals.starlightRoute;
const { data } = route.entry;
const { title = data.title, tagline } = data.hero || {};

// Only the homepage gets the branded, card-forward hero layout.
const isHome = route?.id === "" || route?.entry?.slug === "";
---

{
  isHome ? (
    <div class="hero hero--home flex flex-col items-center mx-auto px-4 sm:px-6 lg:px-8">
      <div class="hero-brand">
        {title && <h1 class="hero-brand__title" set:html={title} />}
        {tagline && <p class="hero-brand__tagline" set:html={tagline} />}
      </div>

      <div class="hero-commons">
        <CommonsCard href="https://app.nanoknow.org" />
      </div>
    </div>
  ) : (
    <div
      class="hero flex flex-col items-center mx-auto px-4 sm:px-6 lg:px-8 pt-36 md:pt-44 lg:pt-56 pb-16"
      style="min-height: min(856px, 85vh);"
    >
      {title && <h1 class="mb-8 text-center rounded-2xl" set:html={title} />}
      {tagline && <p class="tagline-custom text-center" set:html={tagline} />}
    </div>
  )
}

<style>
  @layer starlight.core {
    /* Non-home hero title (kept for parity with other splash pages). */
    .hero:not(.hero--home) h1 {
      font-size: 7rem !important;
      line-height: 6.5rem !important;
      letter-spacing: -4px;
      color: var(--sl-color-white);
    }
    .tagline-custom {
      font-size: 2.25rem;
      margin-top: 0.25rem;
      color: var(--color-text);
    }
    @media (min-width: 1024px) {
      .tagline-custom {
        padding-left: 8rem;
        margin-top: -4rem;
      }
    }
    :root[data-theme="light"] .tagline-custom {
      color: var(--color-lightmode-light) !important;
    }
    @media (max-width: 940px) {
      .hero:not(.hero--home) h1 {
        font-size: 3.5rem !important;
        line-height: 3.5rem !important;
        letter-spacing: -2px;
      }
    }

    /* ---------- Home hero ---------- */
    .hero--home {
      /* Pulled up: the logo sits closer to the top, leaving room for the card. */
      padding-top: clamp(4rem, 7vw, 6.5rem);
      padding-bottom: clamp(2.5rem, 5vw, 4rem);
    }

    /* Centered wordmark: title with the tagline set like a lockup beneath it. */
    .hero-brand {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      width: 100%;
    }

    .hero-brand__title {
      font-size: clamp(3.25rem, 8vw, 6.5rem) !important;
      line-height: 1 !important;
      letter-spacing: -3px;
      color: var(--sl-color-white);
      margin: 0 !important;
    }

    /* Small-caps lockup line under the wordmark. */
    .hero-brand__tagline {
      font-size: clamp(0.85rem, 1.6vw, 1.2rem);
      font-weight: 500;
      line-height: 1.3;
      text-transform: uppercase;
      letter-spacing: clamp(0.28em, 0.5vw, 0.42em);
      /* Optical centering: letter-spacing adds a trailing gap after the last
         character, so nudge the line right by half a tracking unit. */
      text-indent: clamp(0.28em, 0.5vw, 0.42em);
      margin: 1.1rem 0 0;
      color: var(--color-text);
    }

    :root[data-theme="light"] .hero-brand__tagline {
      color: var(--color-lightmode-text) !important;
    }

    .hero-commons {
      width: 100%;
      margin-top: clamp(1.75rem, 3.5vw, 3rem);
      display: flex;
      justify-content: center;
    }
  }
</style>
<script>
  // The decorative hero background needs to match the rendered hero height.
  const heroSection = document.querySelector(".hero");
  const header = document.querySelector(".header");
  const heroBG = document.querySelector(".hero-bg") as HTMLElement | null;

  if (heroBG) {
    const totalHeight =
      (heroSection?.clientHeight || 0) + (header?.clientHeight || 0) + 24;
    heroBG.style.height = `${totalHeight}px`;
  }
</script>
