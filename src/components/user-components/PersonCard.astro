---
interface Props {
  name: string;
  role?: string;
  bio?: string;
  image?: string;
}

const { name, role, bio, image } = Astro.props;

const initials = name
  .split(" ")
  .map((part) => part[0])
  .filter(Boolean)
  .slice(0, 2)
  .join("")
  .toUpperCase();
---

<div class="person-card">
  <div class="person-card__avatar">
    {image ? <img src={image} alt={name} /> : <span>{initials}</span>}
  </div>
  <p class="person-card__name">{name}</p>
  {role && <p class="person-card__role">{role}</p>}
  {bio && <p class="person-card__bio">{bio}</p>}
</div>

<style>
  @layer starlight.components {
    .person-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 2.5rem 1.75rem 2rem;
      border-radius: 1rem;
      border: 1px solid var(--sl-color-gray-6);
      position: relative;
      transition: all 0.4s ease;
      height: 100%;
    }

    .person-card::before {
      content: "";
      position: absolute;
      inset: 0;
      padding: 1px;
      background: var(--color-primary-gradient);
      border-radius: inherit;
      mask:
        linear-gradient(#fff 0 0) content-box,
        linear-gradient(#fff 0 0);
      mask-composite: xor;
      -webkit-mask-composite: xor;
      opacity: 0;
      transition: opacity 0.4s ease;
    }

    .person-card:hover::before {
      opacity: 1;
    }

    .person-card__avatar {
      width: 6.5rem;
      height: 6.5rem;
      border-radius: 50%;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--color-primary-gradient);
      margin-bottom: 1.25rem;
      flex-shrink: 0;
    }

    .person-card__avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .person-card__avatar span {
      font-size: 1.75rem;
      font-weight: 600;
      color: #fff;
    }

    .person-card__name {
      font-size: var(--sl-text-h4);
      color: var(--sl-color-white);
      line-height: var(--sl-line-height-headings);
      margin: 0 0 0.25rem;
    }

    .person-card__role {
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--color-lightmode-primary);
      margin: 0 0 0.75rem;
    }

    .person-card__bio {
      margin: 0;
      font-size: clamp(var(--sl-text-body));
      color: var(--sl-color-gray-3);
    }
  }
</style>
