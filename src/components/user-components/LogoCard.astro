---
interface Props {
  src: string;
  alt: string;
  href?: string;
}

const { src, alt, href } = Astro.props;
const Tag = href ? "a" : "div";
---

<Tag
  class="logo-card"
  {...(href ? { href, target: "_blank", rel: "noopener noreferrer" } : {})}
>
  <div class="logo-card__image-wrap">
    <img src={src} alt={alt} class="logo-card__image" />
  </div>
</Tag>

<style>
  @layer starlight.components {
    .logo-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem 1.5rem;
      border-radius: 1rem;
      background: #fff;
      border: 1px solid var(--sl-color-gray-6);
      position: relative;
      transition: all 0.4s ease;
      text-decoration: none;
      color: inherit;
      width: 100%;
    }

    .logo-card::before {
      content: "";
      position: absolute;
      inset: 0;
      padding: 1px;
      background: var(--color-primary-gradient);
      border-radius: inherit;
      mask:
        linear-gradient(#fff 0 0) content-box,
        linear-gradient(#fff 0 0);
      mask-composite: xor;
      -webkit-mask-composite: xor;
      opacity: 0;
      transition: opacity 0.4s ease;
    }

    .logo-card:hover::before {
      opacity: 1;
    }

    .logo-card:hover {
      transform: translateY(-4px);
    }

    .logo-card__image-wrap {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100px;
      width: 100%;
    }

    .logo-card__image {
      max-height: 100%;
      max-width: 100%;
      object-fit: contain;
    }
  }
</style>
